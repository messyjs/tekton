{
  "name": "tekton-agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/voice",
    "packages/tools",
    "packages/hermes-bridge",
    "packages/gateway",
    "packages/dashboard",
    "packages/ml-ops",
    "packages/cli",
    "packages/docling-service",
    "packages/forge"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w @tekton/core -w @tekton/hermes-bridge -w @tekton/tools -w @tekton/voice -w @tekton/gateway -w @tekton/dashboard -w @tekton/ml-ops -w @tekton/docling-service",
    "build:cli": "npm run build -w @tekton/cli",
    "build:forge": "npm run build -w @tekton/forge",
    "test": "vitest run",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}